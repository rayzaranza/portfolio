---
import Wrapper from "@/layouts/Wrapper.astro";
import ModeToggle from "./ModeToggle.astro";
const isActive = (page: string) => Astro.url.pathname.startsWith(page);
---

<header>
  <Wrapper class="wrapper">
    <div class="info">
      <a class="title" aria-hidden="true" href="/">Ray Zaranza</a>
      <span>Desenvolvedor · Designer</span>
    </div>

    <nav class="menu">
      <a
        class="menu-link"
        aria-current={isActive("/projetos") ? "page" : undefined}
        href="/projetos">Projetos</a
      >
      <a
        class="menu-link"
        aria-current={isActive("/sobre") ? "page" : undefined}
        href="/sobre">Sobre</a
      >
    </nav>
    <ModeToggle />
  </Wrapper>
</header>

<style>
  .wrapper {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-200);
    color: var(--color-content-secondary);
  }

  .title {
    font-weight: 700;
    font-size: var(--font-size-200);
    color: var(--color-content);
    text-decoration-line: none;
    &:hover {
      text-decoration-line: underline;
    }
  }

  .info {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: var(--space-050);
  }

  .menu {
    display: none;
    align-items: center;
    gap: var(--space-300);
    font-size: var(--font-size-050);
  }

  .menu-link {
    text-decoration-line: none;
    border-bottom-width: 2px;
    border-bottom-style: dotted;
    border-bottom-color: transparent;

    &[aria-current="page"] {
      color: var(--color-content);
      border-bottom-color: currentColor;
    }

    &:hover {
      text-decoration-line: underline;
    }
  }
  @media screen and (min-width: 576px) {
    .wrapper {
      grid-template-columns: 1fr auto auto;
    }

    .menu {
      display: flex;
    }
  }
</style>
