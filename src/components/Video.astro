---
interface Props {
  src: string;
  caption?: string;
  type?: string;
}

const { src, caption, type = "video/mp4" } = Astro.props;
---

<div class="video-wrapper">
  <video class="video" autoplay muted controls playsinline>
    <source src={src} type={type} />
  </video>
  {caption && <span class="caption">{caption}</span>}
</div>

<style>
  .video {
    margin-block: var(--space-300);
    max-width: 100%;
    border-radius: var(--radius-medium);
    border: 1px solid var(--color-border-secondary);
  }

  .video-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-100);
  }
</style>
