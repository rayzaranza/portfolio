---
import Tag from "./Tag.astro";

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="tag-list">
  {tags.map((tag) => <Tag label={tag} />)}
</ul>

<style>
  .tag-list {
    display: inline-flex;
    gap: var(--space-100);
    align-items: center;
    flex-wrap: wrap;
  }
</style>
