---
import { ChevronUpIcon } from "astro-feather";

type Route = "/" | "/projetos" | `projetos/${string}` | "/sobre";

interface Props {
  href: Route | string;
  className?: string;
  isExternal?: boolean;
  isActive?: boolean;
  isInline?: boolean;
}

const {
  href,
  isExternal = false,
  isActive = false,
  isInline = true,
  className,
} = Astro.props;
---

<a
  class:list={["link", isInline && "inline", className]}
  aria-current={isActive}
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  data-astro-prefetch={isExternal && "false"}
>
  <slot />
  {
    isActive && (
      <span class="active-indicator">
        <ChevronUpIcon size={16} />
      </span>
    )
  }
</a>

<style>
  .link {
    display: inline-flex;
    align-items: center;
    color: var(--color-content-secondary);
    font-size: var(--font-size-050);
    gap: var(--space-050);
    text-decoration-line: none;
    font-weight: 500;
    position: relative;

    &:hover {
      color: var(--color-content);
      text-decoration-line: underline;
    }
  }

  .link[aria-current="true"] {
    color: var(--color-content);
    text-decoration: none;
  }

  .active-indicator {
    position: absolute;
    top: var(--space-200);
    display: flex;
    justify-content: center;
    inset-inline: 0;
    color: var(--color-content-secondary);
  }

  .inline {
    text-decoration-line: underline;

    &:hover {
      color: var(--color-content);
      text-decoration-line: none;
    }
  }
</style>
