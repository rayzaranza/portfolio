---
import { type IconName, icons } from "@/icons";

interface Props {
  name: IconName;
  size?: string | number;
  class?: string;
}

const { name, size = 24, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  set:html={icons[name]}
/>
