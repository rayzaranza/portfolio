---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Tag from "./Tag.astro";
import TagList from "./TagList.astro";
import { GithubIcon, GlobeIcon } from "astro-feather";
import Link from "./Link.astro";

interface Props {
  project: CollectionEntry<"projects">;
  variant?: "list" | "grid";
}

const { project, variant = "list" } = Astro.props;
const { cover, alt, title, description, tags, year, github, website } =
  project.data;

const links = [
  { Icon: GithubIcon, href: github, label: "GitHub" },
  { Icon: GlobeIcon, href: website, label: "Site" },
];
---

<li>
  <article class:list={["project-card", variant]}>
    <Image class="image" src={cover} alt={alt} />
    <div class="content">
      <header class="header">
        <Link href={`/projetos/${project.id}`}
          ><h3 class="title">
            {title}
            <span class="year"> · {year}</span>
          </h3></Link
        >
        <TagList tags={tags} />
        {variant === "list" && <p class="description">{description}</p>}
      </header>
      {
        variant === "list" && (
          <footer>
            <ul class="links">
              {links.map(
                ({ href, Icon, label }) =>
                  href && (
                    <li>
                      <Link href={href} isExternal>
                        <Icon width={18} /> {label}
                      </Link>
                    </li>
                  ),
              )}
            </ul>
          </footer>
        )
      }
    </div>
  </article>
</li>

<style>
  .project-card {
    display: grid;
    row-gap: var(--space-200);
    column-gap: var(--space-400);
  }

  .description {
    color: var(--color-content-secondary);
  }

  .grid {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    gap: var(--space-200);
  }

  .header,
  .content {
    display: flex;
    flex-direction: column;
  }

  .header {
    gap: var(--space-200);
  }

  .tags,
  .links {
    display: flex;
    align-items: center;
  }

  .links {
    color: var(--color-content-secondary);
    font-size: var(--font-size-050);
    gap: var(--space-200);
  }

  @media screen and (min-width: 576px) {
    .list {
      grid-template-columns: 1fr 1.33fr;
    }

    .links {
      display: flex;
    }
  }

  .image {
    width: 100%;
    height: 100%;
    min-width: 128px;
  }

  .title {
    color: var(--color-content);
  }

  .year {
    color: var(--color-content-secondary);
    font-weight: 400;
  }

  .tags {
    gap: var(--space-100);
  }
</style>
