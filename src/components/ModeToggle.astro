---
import { SunIcon, MoonIcon } from "astro-feather";
---

<button class="square" aria-label="Alterar modo de cores" data-mode-toggle>
  <MoonIcon customClasses="icon dark" />
  <SunIcon customClasses="icon light" />
</button>

<script>
  function handleToggle() {
    const toggle = document.querySelector("[data-mode-toggle]");
    toggle?.addEventListener("click", () => {
      const newMode =
        localStorage.getItem("mode") === "dark" ? "light" : "dark";
      localStorage.setItem("mode", newMode);
      document.documentElement.dataset.mode = newMode;
    });
  }

  handleToggle();
  document.addEventListener("astro:after-swap", handleToggle);
</script>

<style>
  :root[data-mode="dark"] :global(.icon.light) {
    display: none;
  }
  :root[data-mode="light"] :global(.icon.dark) {
    display: none;
  }
</style>
