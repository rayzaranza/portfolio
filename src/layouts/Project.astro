---
import Link from "@/components/Link.astro";
import RootLayout from "./RootLayout.astro";
import Wrapper from "./Wrapper.astro";
import {
  ArrowLeftIcon,
  ExternalLinkIcon,
  GithubIcon,
  GlobeIcon,
} from "astro-feather";
import TagList from "@/components/TagList.astro";
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, tags, github, website, cover, alt, year, client, company } =
  project.data;
---

<RootLayout pageTitle={"Projeto · " + title}>
  <Wrapper>
    <header class="header">
      <Link href="/projetos"><ArrowLeftIcon />Projetos</Link>
      <h1>{title}</h1>
      <TagList tags={tags} />
      <Image
        class="cover"
        loading="eager"
        transition:name={`${project.id}-cover`}
        src={cover}
        alt={alt}
      />
    </header>

    <main>
      <section class="intro">
        <dl class="details">
          <div>
            <dt>Ano</dt>
            <dd>{year}</dd>
          </div>
          {
            company && (
              <div>
                <dt>Empresa</dt>
                <dd>{company}</dd>
              </div>
            )
          }
          {
            client && (
              <div>
                <dt>Cliente</dt>
                <dd>{client}</dd>
              </div>
            )
          }
          <div class="links">
            <dt class="visually-hidden">Links</dt>
            {
              github && (
                <dt>
                  <Link className="button bordered" href={github} isExternal>
                    <GithubIcon /> GitHub <ExternalLinkIcon size={16} />
                  </Link>
                </dt>
              )
            }
            {
              website && (
                <dd>
                  <Link className="button bordered" href={website} isExternal>
                    <GlobeIcon /> Site <ExternalLinkIcon size={16} />
                  </Link>
                </dd>
              )
            }
          </div>
        </dl>
      </section>

      <section class="content">
        <slot />
      </section>
      <hr />
    </main>
  </Wrapper>

  <style>
    .header {
      display: flex;
      flex-direction: column;
      gap: var(--space-200);
    }

    .cover {
      margin-top: var(--space-100);
      margin-bottom: var(--space-400);
    }

    .content {
      margin-bottom: var(--space-600);

      a,
      a > span {
        font-size: inherit;
        color: inherit;
      }

      h1,
      h2,
      h3 {
        margin-block-end: var(--space-200);
      }

      h2 {
        margin-top: var(--space-500);
      }

      img {
        border: 1px solid var(--color-border-secondary);
      }

      ul {
        list-style: inside circle;
        margin-block-end: var(--space-400);

        li {
          margin-block-end: var(--space-100);
        }
      }
    }

    .links {
      display: flex;
      align-items: baseline;
      gap: var(--space-100);
    }

    .details {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-600);
      row-gap: var(--space-300);
      align-items: center;
      align-content: center;
      justify-content: start;
      width: 100%;
    }

    .intro {
      display: flex;
      gap: var(--space-200);
      padding-bottom: var(--space-300);
      margin-bottom: var(--space-400);
      border-bottom: 1px solid var(--color-border-secondary);

      @media screen and (min-width: 720px) {
        gap: var(--space-400);
      }
    }
  </style>
</RootLayout>
